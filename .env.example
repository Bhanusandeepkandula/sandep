# Copy to `.env.local` and fill from Firebase Console → Project settings → Your apps → SDK setup.
# https://vitejs.dev/guide/env-and-mode.html

# GitHub Pages (project site at https://user.github.io/REPO/): set before `vite build`, e.g.
# VITE_BASE_PATH=/REPO/
# User/org site (repo named user.github.io, URL https://user.github.io/): use VITE_BASE_PATH=/
# Leave unset for local dev (defaults to /).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=

# If Firestore Listen shows blocked/failed: set to true (uses long-polling instead of WebChannel only).
# VITE_FIREBASE_FORCE_LONG_POLLING=true

# Local dev / vite preview — Vite proxy adds x-api-key (never commit real keys).
# Get a key: https://console.anthropic.com/ → API keys
ANTHROPIC_API_KEY=
# If you mistakenly used the Vite prefix, this works too (same file, pick one name):
# VITE_ANTHROPIC_API_KEY=

# Firebase Console → Authentication → Sign-in method: enable Email/Password (required for PIN profiles).
