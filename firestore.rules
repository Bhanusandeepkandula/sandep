rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /config/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Lets each signed-in user publish their app profile id → Firebase uid so friends can sync split bills.
    match /peerProfileIndex/{profileId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /users/{userId}/settings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Split bills: a friend may create/update/delete a *mirror* copy in your transactions if they mark syncedFromUid.
    match /users/{userId}/transactions/{txId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null && (
        request.auth.uid == userId
        || request.resource.data.syncedFromUid == request.auth.uid
      );

      // Narrow rule for a slave paying back: lets them update *only* their own slot in
      // the `settlements` map on someone else's transaction. Keyed by their Firebase uid
      // so nobody can overwrite another peer's settlement record.
      function isPeerSettlementUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['settlements'])
          && request.resource.data.settlements
               .diff(resource.data.get('settlements', {}))
               .affectedKeys().hasOnly([request.auth.uid]);
      }

      allow update: if request.auth != null && (
        request.auth.uid == userId
        || resource.data.syncedFromUid == request.auth.uid
        || isPeerSettlementUpdate()
      );

      allow delete: if request.auth != null && (
        request.auth.uid == userId
        || resource.data.syncedFromUid == request.auth.uid
      );
    }
  }
}
